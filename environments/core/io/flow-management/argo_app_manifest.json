{
  "apiVersion": "argoproj.io/v1alpha1",
  "kind": "Application",
  "metadata": {
    "name": "flow-management",
    "namespace": "argocd",
    "finalizers": [
      "resources-finalizer.argocd.argoproj.io"
    ]
  },
  "spec": {
    "project": "io",
    "source": {
      "helm": {
        "valueFiles": [
          "../../io/flow-management/microservice.yaml",
          "../../io/flow-management/env.yaml"
        ]
      },
      "path": "charts/microservice",
      "repoURL": "https://github.com/celigo/cd.git",
      "targetRevision": "core"
    },
    "destination": {
      "namespace": "io",
      "server": "https://kubernetes.default.svc"
    },
    "syncPolicy": {
      "automated": {
        "prune": true,
        "selfHeal": true
      },
      "syncOptions": [
        "CreateNamespace=true"
      ]
    }
  }
}
