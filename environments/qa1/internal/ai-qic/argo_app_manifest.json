{
    "apiVersion": "argoproj.io/v1alpha1",
    "kind": "Application",
    "metadata": {
        "name": "ai-qic",
        "namespace": "argocd",
        "finalizers": [
            "resources-finalizer.argocd.argoproj.io"
        ]
    },
    "spec": {
        "project": "internal",
        "source": {
            "helm": {
                "valueFiles": [
                    "../../internal/ai-qic/microservice.yaml",
                    "../../internal/ai-qic/env.yaml"
                ]
            },
            "path": "charts/microservice",
            "repoURL": "https://github.com/celigo/cd.git",
            "targetRevision": "qa1"
        },
        "destination": {
            "namespace": "internal",
            "server": "https://kubernetes.default.svc"
        },
        "syncPolicy": {
            "automated": {
                "prune": true,
                "selfHeal": true
            },
            "syncOptions": [
                "CreateNamespace=true"
            ]
        }
    }
}
