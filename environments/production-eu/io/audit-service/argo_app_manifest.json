{
  "apiVersion": "argoproj.io/v1alpha1",
  "kind": "Application",
  "metadata": {
      "name": "audit-service",
      "namespace": "argocd",
      "finalizers": [
          "resources-finalizer.argocd.argoproj.io"
      ]
  },
  "spec": {
      "project": "io",
      "source": {
          "helm": {
              "valueFiles": [
                  "../../io/audit-service/microservice.yaml",
                  "../../io/audit-service/env.yaml"
              ]
          },
          "path": "charts/microservice",
          "repoURL": "https://github.com/celigo/cd-prod.git",
          "targetRevision": "production-eu"
      },
      "destination": {
          "namespace": "io",
          "server": "https://kubernetes.default.svc"
      },
      "syncPolicy": {
          "automated": {
              "prune": true,
              "selfHeal": true
          },
          "syncOptions": [
              "CreateNamespace=true"
          ]
      }
  }
}