{
    "apiVersion": "argoproj.io/v1alpha1",
    "kind": "Application",
    "metadata": {
        "name": "telemetry",
        "namespace": "argocd",
        "finalizers": [
            "resources-finalizer.argocd.argoproj.io"
        ]
    },
    "spec": {
        "project": "default",
        "source": {
            "directory": {
                "recurse": true,
                "jsonnet": {},
                "exclude": "*.json"
            },
            "path": "tools/telemetry",
            "repoURL": "https://github.com/celigo/cd-prod.git",
            "targetRevision": "production-eu"
        },
        "destination": {
            "server": "https://kubernetes.default.svc"
        },
        "syncPolicy": {
            "automated": {
                "prune": true,
                "selfHeal": true
            },
            "syncOptions": [
                "CreateNamespace=true"
            ]
        }
    }
}