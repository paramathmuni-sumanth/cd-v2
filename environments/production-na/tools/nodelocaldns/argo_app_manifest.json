{
    "apiVersion": "argoproj.io/v1alpha1",
    "kind": "Application",
    "metadata": {
        "finalizers": [
            "resources-finalizer.argocd.argoproj.io"
        ],
        "name": "nodelocaldns",
        "namespace": "argocd"
    },
    "spec": {
        "destination": {
            "server": "https://kubernetes.default.svc"
        },
        "project": "foundationlayer",
        "source": {
            "directory": {
                "jsonnet": {},
                "recurse": true
            },
            "path": "tools/nodelocaldns",
            "repoURL": "https://github.com/celigo/cd-prod.git",
            "targetRevision": "production-na"
        },
        "syncPolicy": {
            "automated": {
                "prune": true,
                "selfHeal": true
            },
            "syncOptions": [
                "CreateNamespace=true"
            ]
        }
    }
}