{
  "apiVersion": "argoproj.io/v1alpha1",
  "kind": "Application",
  "metadata": {
    "name": "internal-gateway",
    "namespace": "argocd",
    "finalizers": [
      "resources-finalizer.argocd.argoproj.io"
    ]
  },
  "spec": {
    "project": "io",
    "source":{
      "helm":{
        "valueFiles": [
        "../../io/internal-gateway/microservice.yaml",
        "../../io/internal-gateway/env.yaml"
        ]
      },
      "path": "charts/microservice",
      "repoURL": "https://github.com/celigo/cd-prod.git",
      "targetRevision": "production-na"
    },
    "destination":{
      "namespace": "io",
      "server": "https://kubernetes.default.svc"
    },
    "syncPolicy":{
      "automated":{
        "prune": true,
        "selfHeal": true
      },
      "syncOptions": [
        "CreateNamespace=true"
      ]
    }
  }
}
