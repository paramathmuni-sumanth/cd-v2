{
    "apiVersion": "argoproj.io/v1alpha1",
    "kind": "Application",
    "metadata": {
        "name": "k8s-job-for-scripts",
        "namespace": "argocd",
        "finalizers": [
            "resources-finalizer.argocd.argoproj.io"
        ]
    },
    "spec": {
        "project": "default",
        "source": {
            "helm": {
                "valueFiles": [
                    "values.yaml"
                ]
            },
            "path": "charts/k8s-job-for-scripts",
            "repoURL": "https://github.com/celigo/cd.git",
            "targetRevision": "qa-prod"
        },
        "destination": {
            "namespace": "k8s-job-for-scripts",
            "server": "https://kubernetes.default.svc"
        },
        "syncPolicy": {
            "automated": {
                "prune": true,
                "selfHeal": true
            },
            "syncOptions": [
                "CreateNamespace=true"
            ]
        }
    }
}